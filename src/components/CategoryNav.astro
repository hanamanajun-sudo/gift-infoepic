---
interface Category {
  label: string;
  href: string;
  icon: string;
  count?: number;
  active?: boolean;
}

interface Props {
  categories?: Category[];
  activeHref?: string;
}

const defaultCategories: Category[] = [
  { label: '나이별', href: '/나이/', icon: 'ti-users' },
  { label: '상황별', href: '/상황/', icon: 'ti-calendar' },
  { label: '관계별', href: '/관계/', icon: 'ti-heart' },
  { label: '예산별', href: '/예산/', icon: 'ti-wallet' },
];

const { categories = defaultCategories, activeHref } = Astro.props;
const currentPath = activeHref ?? Astro.url.pathname;
---

<nav class="category-nav" aria-label="카테고리">
  {categories.map(cat => {
    const isActive = currentPath === cat.href || currentPath.startsWith(cat.href);
    return (
      <a
        href={cat.href}
        class:list={['cat-link', { active: isActive }]}
        aria-current={isActive ? 'page' : undefined}
      >
        <i class={`ti ${cat.icon}`} aria-hidden="true"></i>
        <span>{cat.label}</span>
        {cat.count != null && (
          <span class="cat-count">{cat.count}</span>
        )}
      </a>
    );
  })}
</nav>

<style>
  .category-nav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin: var(--space-6) 0;
  }

  .cat-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-muted);
    background: var(--color-bg-subtle);
    border: 1.5px solid var(--color-border);
    text-decoration: none;
    transition: all var(--transition-fast);
  }
  .cat-link:hover {
    background: var(--color-primary-light);
    border-color: var(--color-primary-light);
    color: var(--color-primary-dark);
  }
  .cat-link.active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: white;
  }
  .cat-link.active:hover { background: var(--color-primary-dark); }

  .cat-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 20px;
    height: 20px;
    padding: 0 6px;
    background: rgba(255,255,255,0.3);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-bold);
  }
  .cat-link:not(.active) .cat-count {
    background: var(--color-border);
    color: var(--color-text-muted);
  }
</style>
