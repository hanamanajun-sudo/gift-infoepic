---
import type { Heading } from '../lib/notion';

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const h2Only = headings.filter(h => h.level === 2);
---

{h2Only.length > 0 && (
  <div class="toc" aria-label="목차">
    <p class="toc-title">
      <i class="ti ti-list" aria-hidden="true"></i>
      목차
    </p>
    <ol class="toc-list">
      {h2Only.map((h, i) => (
        <li class="toc-item">
          <a href={`#${h.id}`} class="toc-link" data-heading-id={h.id}>
            <span class="toc-num">{i + 1}</span>
            <span class="toc-text">{h.text}</span>
          </a>
        </li>
      ))}
    </ol>
  </div>
)}

<script is:inline>
  (function () {
    var links = document.querySelectorAll('.toc-link[data-heading-id]');
    if (!links.length) return;

    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          links.forEach(function (l) { l.classList.remove('active'); });
          var id = entry.target.getAttribute('id');
          var active = document.querySelector('.toc-link[data-heading-id="' + id + '"]');
          if (active) active.classList.add('active');
        }
      });
    }, { rootMargin: '-10% 0% -80% 0%' });

    links.forEach(function (link) {
      var id = link.getAttribute('data-heading-id');
      var heading = document.getElementById(id);
      if (heading) observer.observe(heading);
    });
  })();
</script>

<style>
  .toc {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-5);
    background: var(--color-bg-subtle);
  }

  .toc-title {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    margin-bottom: var(--space-4);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .toc-link {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-2);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
    transition: all var(--transition-fast);
  }
  .toc-link:hover {
    background: var(--color-primary-light);
    color: var(--color-primary-dark);
  }
  .toc-link.active {
    color: var(--color-primary);
    font-weight: var(--font-weight-semibold);
  }

  .toc-num {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-xs);
    font-weight: var(--font-weight-bold);
    background: var(--color-border);
    border-radius: var(--radius-full);
    margin-top: 1px;
  }
  .toc-link.active .toc-num {
    background: var(--color-primary);
    color: white;
  }

  .toc-text { flex: 1; }
</style>
