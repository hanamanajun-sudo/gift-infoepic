---
import type { GiftGuide } from '../lib/notion';
import { formatPriceRange } from '../lib/notion';

interface Props {
  guide: GiftGuide;
}

const { guide } = Astro.props;

const thumbBg =
  guide.recipientGender?.includes('여') ? '#FCE7F3' :
  guide.recipientGender?.includes('남') ? '#DBEAFE' :
  '#EDE9FE';

const thumbColor =
  guide.recipientGender?.includes('여') ? '#BE185D' :
  guide.recipientGender?.includes('남') ? '#1E40AF' :
  '#6D28D9';

const thumbIcon =
  guide.occasion.includes('크리스마스') ? 'ti-christmas-tree' :
  guide.occasion.includes('어린이날') ? 'ti-confetti' :
  guide.occasion.includes('졸업')     ? 'ti-school' :
  guide.occasion.includes('어버이날') ? 'ti-heart-handshake' :
  'ti-gift';

const priceRange = formatPriceRange(guide.priceMin, guide.priceMax);
---

<article class="gift-card">
  <a href={`/선물/${guide.slug}/`} class="card-thumb-link" tabindex="-1" aria-hidden="true">
    {guide.thumbnail ? (
      <img
        src={guide.thumbnail}
        alt={guide.title}
        class="card-thumb-img"
        loading="lazy"
        decoding="async"
        width="400"
        height="220"
      />
    ) : (
      <div class="card-thumb-placeholder" style={`background:${thumbBg}`}>
        <i class={`ti ${thumbIcon}`} style={`color:${thumbColor}`} aria-hidden="true"></i>
      </div>
    )}
  </a>

  <div class="card-body">
    <div class="card-badges">
      {guide.occasion.slice(0, 2).map(o => (
        <a href={`/상황/${o}/`} class="badge badge-primary">{o}</a>
      ))}
      {guide.recipientGender && guide.recipientGender !== '공통' && (
        <span class={`badge ${guide.recipientGender.includes('여') ? 'badge-gender-f' : 'badge-gender-m'}`}>
          {guide.recipientGender}
        </span>
      )}
    </div>

    <h2 class="card-title">
      <a href={`/선물/${guide.slug}/`}>{guide.title}</a>
    </h2>

    {guide.intro && (
      <p class="card-intro">{guide.intro}</p>
    )}

    <div class="card-footer">
      {priceRange && (
        <span class="card-price">
          <i class="ti ti-wallet" aria-hidden="true"></i>
          {priceRange}
        </span>
      )}
      <a href={`/선물/${guide.slug}/`} class="card-cta" aria-label={`${guide.title} 자세히 보기`}>
        보기 <i class="ti ti-arrow-right" aria-hidden="true"></i>
      </a>
    </div>
  </div>
</article>

<style>
  .gift-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
    display: flex;
    flex-direction: column;
  }
  .gift-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
  }

  /* 썸네일 */
  .card-thumb-link { display: block; aspect-ratio: 16/9; overflow: hidden; }
  .card-thumb-img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 300ms ease;
  }
  .gift-card:hover .card-thumb-img { transform: scale(1.03); }
  .card-thumb-placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    font-size: 3rem;
  }

  /* 본문 */
  .card-body {
    padding: var(--space-4) var(--space-5) var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
  }

  .card-badges {
    display: flex; flex-wrap: wrap; gap: var(--space-1);
  }

  .card-title {
    font-size: var(--text-base);
    font-weight: var(--font-weight-semibold);
    line-height: var(--leading-snug);
    flex: 1;
  }
  .card-title a {
    color: var(--color-text);
    text-decoration: none;
  }
  .card-title a:hover { color: var(--color-primary); }

  .card-intro {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: var(--space-2);
  }

  .card-price {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-muted);
  }
  .card-price i { font-size: 0.85em; }

  .card-cta {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-primary);
    text-decoration: none;
    transition: gap var(--transition-fast);
  }
  .card-cta:hover { gap: 6px; color: var(--color-primary-dark); }
</style>
