---
import type { Product } from '../lib/notion';

interface Props {
  product: Product;
  index: number;
}

const { product, index } = Astro.props;

const rankColors: Record<number, string> = {
  1: '#F59E0B',
  2: '#9CA3AF',
  3: '#CD7C2F',
};
const rankColor = rankColors[index + 1] ?? 'var(--color-primary)';
---

<article class="product-card" id={`product-${index + 1}`}>
  <!-- 순위 배지 -->
  <div class="rank-badge" style={`background:${rankColor}`} aria-label={`${index + 1}위`}>
    {index + 1}
  </div>

  <!-- 이미지 -->
  <div class="product-img-wrap">
    {product.imageUrl ? (
      <img
        src={product.imageUrl}
        alt={product.name}
        class="product-img"
        loading="lazy"
        decoding="async"
        width="160"
        height="160"
      />
    ) : (
      <div class="product-img-placeholder" aria-hidden="true">
        <i class="ti ti-package"></i>
      </div>
    )}
  </div>

  <!-- 정보 -->
  <div class="product-info">
    <h3 class="product-name">{product.name}</h3>

    {product.price && (
      <p class="product-price">
        {product.price.toLocaleString('ko-KR')}원
      </p>
    )}

    {product.pros && (
      <p class="product-pros">{product.pros}</p>
    )}

    <!-- 구매 링크 -->
    <div class="product-links">
      {product.coupangUrl && product.coupangUrl !== '#' && (
        <a
          href={product.coupangUrl}
          target="_blank"
          rel="noopener noreferrer sponsored"
          class="product-link-btn coupang"
        >
          <i class="ti ti-shopping-cart" aria-hidden="true"></i>
          쿠팡에서 최저가 확인
        </a>
      )}
      {product.naverUrl && product.naverUrl !== '#' && (
        <a
          href={product.naverUrl}
          target="_blank"
          rel="noopener noreferrer nofollow"
          class="product-link-btn naver"
        >
          <i class="ti ti-external-link" aria-hidden="true"></i>
          네이버 쇼핑
        </a>
      )}
      {(!product.coupangUrl || product.coupangUrl === '#') && (!product.naverUrl || product.naverUrl === '#') && (
        <span class="product-link-placeholder">링크 준비 중</span>
      )}
    </div>
  </div>
</article>

<style>
  .product-card {
    display: flex;
    gap: var(--space-4);
    padding: var(--space-5);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    position: relative;
    transition: box-shadow var(--transition-fast);
  }
  .product-card:hover { box-shadow: var(--shadow-md); }

  /* 순위 */
  .rank-badge {
    position: absolute;
    top: -10px;
    left: var(--space-5);
    width: 28px;
    height: 28px;
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-sm);
    font-weight: var(--font-weight-bold);
    color: white;
  }

  /* 이미지 */
  .product-img-wrap {
    flex-shrink: 0;
    width: 100px;
    height: 100px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-bg-subtle);
  }
  .product-img { width: 100%; height: 100%; object-fit: cover; }
  .product-img-placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    font-size: 2rem; color: var(--color-text-light);
  }

  /* 정보 */
  .product-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    min-width: 0;
  }

  .product-name {
    font-size: var(--text-base);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
    line-height: var(--leading-snug);
  }

  .product-price {
    font-size: var(--text-lg);
    font-weight: var(--font-weight-bold);
    color: var(--color-primary-dark);
  }

  .product-pros {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* 구매 링크 */
  .product-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-1);
  }

  .product-link-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    text-decoration: none;
    transition: all var(--transition-fast);
  }
  .product-link-btn.coupang {
    background: #FEF3C7;
    color: #92400E;
  }
  .product-link-btn.coupang:hover { background: #F59E0B; color: white; }
  .product-link-btn.naver {
    background: #DCFCE7;
    color: #14532D;
  }
  .product-link-btn.naver:hover { background: #16A34A; color: white; }

  .product-link-placeholder {
    font-size: var(--text-xs);
    color: var(--color-text-light);
    padding: var(--space-2) 0;
  }

  @media (max-width: 480px) {
    .product-card { flex-direction: column; }
    .product-img-wrap { width: 100%; height: 160px; }
  }
</style>
