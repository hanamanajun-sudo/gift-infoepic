---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import TOC from '../components/TOC.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { GiftGuide, Heading, Product } from '../lib/notion';
import { formatPriceRange } from '../lib/notion';

interface Props {
  guide: GiftGuide;
  headings: Heading[];
  products: Product[];
}

const { guide, headings, products } = Astro.props;

const SITE = 'https://gift.infoepic.com';

const breadcrumbs = [
  { label: '홈', href: '/' },
  ...(guide.occasion[0] ? [{ label: guide.occasion[0], href: `/상황/${guide.occasion[0]}/` }] : []),
  { label: guide.title, href: '' },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": guide.title,
  "description": guide.description,
  "numberOfItems": products.length,
  "itemListElement": products.map((p, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": p.name,
    "url": p.coupangUrl || p.naverUrl || `${SITE}/선물/${guide.slug}/`,
  })),
};
---

<BaseLayout
  title={`${guide.title} (2026년 최신)`}
  description={guide.description}
  ogImage={guide.thumbnail || undefined}
  pageType="article"
  jsonLd={jsonLd}
>
  <Header />

  <div class="guide-page container">
    <div class="guide-layout">
      <!-- 메인 콘텐츠 -->
      <main class="guide-main" id="main-content">
        <Breadcrumb items={breadcrumbs} />

        <header class="guide-header">
          <div class="guide-meta">
            {guide.occasion.map(o => (
              <a href={`/상황/${o}/`} class="badge badge-primary">{o}</a>
            ))}
            {guide.recipientGender && guide.recipientGender !== '공통' && (
              <span class={`badge ${guide.recipientGender.includes('여') ? 'badge-gender-f' : 'badge-gender-m'}`}>
                {guide.recipientGender}
              </span>
            )}
            {guide.priceMin || guide.priceMax ? (
              <span class="badge badge-accent">
                <i class="ti ti-wallet" style="font-size:0.8em"></i>
                {formatPriceRange(guide.priceMin, guide.priceMax)}
              </span>
            ) : null}
          </div>

          <h1 class="guide-title">{guide.title}</h1>

          {guide.intro && <p class="guide-intro">{guide.intro}</p>}

          <div class="guide-meta-bottom">
            <p class="guide-updated">
              <i class="ti ti-clock" aria-hidden="true"></i>
              최근 업데이트: {guide.updatedAt.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}
            </p>
            <button class="share-btn" id="guide-share-btn" aria-label="공유하기">
              <i class="ti ti-share" aria-hidden="true"></i>
              공유하기
            </button>
          </div>
        </header>

        <slot />
      </main>

      <!-- TOC 사이드바 -->
      {headings.length > 0 && (
        <aside class="guide-sidebar" aria-label="목차">
          <TOC headings={headings} />
        </aside>
      )}
    </div>
  </div>

  <Footer />
</BaseLayout>

<script is:inline>
  (function () {
    var btn = document.getElementById('guide-share-btn');
    if (!btn) return;

    btn.addEventListener('click', async function () {
      var url = window.location.href;
      var title = document.title;

      if (navigator.share) {
        try {
          await navigator.share({ title: title, url: url });
        } catch (e) {}
      } else {
        try {
          await navigator.clipboard.writeText(url);
          btn.innerHTML = '<i class="ti ti-check"></i> 복사 완료';
          setTimeout(function () {
            btn.innerHTML = '<i class="ti ti-share"></i> 공유하기';
          }, 2000);
        } catch (e) {}
      }
    });
  })();
</script>

<style>
  .guide-page {
    padding-top: var(--space-8);
    padding-bottom: var(--space-16);
  }

  .guide-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
  }

  @media (min-width: 1024px) {
    .guide-layout {
      grid-template-columns: 1fr 220px;
      align-items: start;
    }
  }

  /* 헤더 */
  .guide-header { margin-bottom: var(--space-8); }

  .guide-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .guide-title {
    font-size: clamp(var(--text-2xl), 4vw, var(--text-4xl));
    font-weight: var(--font-weight-bold);
    line-height: var(--leading-snug);
    color: var(--color-text);
    margin-bottom: var(--space-5);
  }

  .guide-intro {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
    padding: var(--space-5);
    background: var(--color-bg-subtle);
    border-radius: var(--radius-lg);
    border-left: 4px solid var(--color-primary);
  }

  .guide-meta-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .guide-updated {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    background: white;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-text);
    cursor: pointer;
    transition: all var(--transition-fast);
    font-family: inherit;
  }
  .share-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    background: var(--color-primary-light);
  }

  /* 사이드바 */
  .guide-sidebar {
    order: -1;
  }

  @media (min-width: 1024px) {
    .guide-sidebar {
      order: 1;
      position: sticky;
      top: 80px;
    }
  }
</style>
