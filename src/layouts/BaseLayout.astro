---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  pageType?: 'website' | 'article';
  noindex?: boolean;
  jsonLd?: object;
}

const {
  title,
  description = '나이, 관계, 예산으로 찾는 완벽한 생일선물 추천 플랫폼. 13세 여아부터 30대 부모님까지 신뢰할 수 있는 선물 가이드.',
  canonical,
  ogImage,
  pageType = 'website',
  noindex = false,
  jsonLd,
} = Astro.props;

const SITE = 'https://gift.infoepic.com';
const isIndexable = !noindex && import.meta.env.PUBLIC_INDEXABLE !== 'false';

const canonicalUrl = canonical ?? `${SITE}${Astro.url.pathname}`;
const ogImageUrl = ogImage ? ogImage : `${SITE}/og-default.png`;
const fullTitle = title.includes('선물추천') ? title : `${title} | 선물추천 가이드`;
---

<!doctype html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />
  <meta name="naver-site-verification" content="85d1c2fab0faa687b1455ab056f29a6987aa5172" />

  {!isIndexable && <meta name="robots" content="noindex, nofollow" />}

  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:type"        content={pageType} />
  <meta property="og:title"       content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url"         content={canonicalUrl} />
  <meta property="og:image"       content={ogImageUrl} />
  <meta property="og:site_name"   content="선물추천 가이드" />
  <meta property="og:locale"      content="ko_KR" />

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImageUrl} />

  <!-- Pretendard -->
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.css" />

  <!-- Tabler Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.34.0/dist/tabler-icons.min.css" />

  <!-- Pagefind (generated after build) -->
  <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- JSON-LD -->
  {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

  <!-- WebSite JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "선물추천 가이드",
    "url": SITE,
    "description": description,
    "potentialAction": {
      "@type": "SearchAction",
      "target": `${SITE}/search?q={search_term_string}`,
      "query-input": "required name=search_term_string"
    }
  })} />

  <slot name="head" />

  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-NQTCBQDJF5"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-NQTCBQDJF5');
  </script>
</head>
<body>
  <slot />

  <!-- Search Modal -->
  <div id="search-overlay" class="search-overlay" aria-hidden="true">
    <div class="search-backdrop" id="search-backdrop"></div>
    <div class="search-modal" role="dialog" aria-modal="true" aria-label="검색">
      <div class="search-modal-top">
        <p class="search-hint-text"><kbd>ESC</kbd> 또는 배경 클릭으로 닫기</p>
        <button class="search-modal-close" id="search-modal-close" aria-label="닫기">
          <i class="ti ti-x" aria-hidden="true"></i>
        </button>
      </div>
      <div id="pagefind-search-ui"></div>
    </div>
  </div>

  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline>
    (function () {
      var overlay  = document.getElementById('search-overlay');
      var backdrop = document.getElementById('search-backdrop');
      var closeBtn = document.getElementById('search-modal-close');
      var initialized = false;

      function openSearch() {
        overlay.classList.add('open');
        overlay.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
        if (!initialized && typeof PagefindUI !== 'undefined') {
          new PagefindUI({ element: '#pagefind-search-ui', showSubResults: true, translations: { placeholder: '선물 검색...' } });
          initialized = true;
        }
        setTimeout(function () { var inp = document.querySelector('#pagefind-search-ui input'); if (inp) inp.focus(); }, 60);
      }
      function closeSearch() {
        overlay.classList.remove('open');
        overlay.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }

      if (backdrop) backdrop.addEventListener('click', closeSearch);
      if (closeBtn) closeBtn.addEventListener('click', closeSearch);
      document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && overlay.classList.contains('open')) closeSearch(); });
      window.addEventListener('open-search', openSearch);
    })();
  </script>
</body>
</html>
