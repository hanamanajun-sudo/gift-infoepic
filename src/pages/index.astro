---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import GiftCard from '../components/GiftCard.astro';
import FilterBar from '../components/FilterBar.astro';
import CategoryNav from '../components/CategoryNav.astro';
import { getGiftGuides } from '../lib/notion';

const guides = await getGiftGuides();
const sorted = [...guides].sort((a, b) => b.updatedAt.getTime() - a.updatedAt.getTime());
const featured = sorted.slice(0, 12);

const quickLinks = [
  { label: '13세 여아 선물', href: '/선물/13세-여자아이-생일선물/' },
  { label: '남자친구 선물', href: '/선물/남자친구-생일선물/' },
  { label: '여자친구 선물', href: '/선물/여자친구-생일선물/' },
  { label: '크리스마스 선물', href: '/선물/크리스마스-선물/' },
  { label: '어버이날 선물', href: '/선물/어버이날-선물/' },
  { label: '졸업선물', href: '/선물/졸업선물/' },
  { label: '엄마 생일선물', href: '/선물/엄마-생일선물/' },
  { label: '5만원이하 선물', href: '/선물/5만원이하-선물/' },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "선물추천 가이드",
  "url": "https://gift.infoepic.com",
  "description": "나이, 관계, 예산으로 찾는 완벽한 생일선물 추천 플랫폼",
};
---

<BaseLayout
  title="2026년 선물추천 가이드 — 나이·관계·예산으로 찾는 완벽한 선물"
  description="13세 여자아이 생일선물부터 남자친구 기념일 선물까지. 연령·관계·예산별 신뢰할 수 있는 선물 추천 가이드."
  jsonLd={jsonLd}
>
  <Header />

  <main id="main-content">
    <!-- ── 히어로 ── -->
    <section class="hero">
      <div class="container">
        <div class="hero-text">
          <h1 class="hero-title">
            선물 고민,<br>
            이제 딱 맞는 걸 찾아드립니다
          </h1>
          <p class="hero-subtitle">
            나이, 관계, 예산 세 가지만 알면 딱 맞는 선물이 보입니다.
            실제 구매자 후기 기반의 신뢰할 수 있는 선물 가이드.
          </p>
        </div>

        <FilterBar />

        <!-- 빠른 검색 -->
        <div class="quick-links">
          <span class="quick-label">자주 찾는 선물</span>
          <div class="quick-pills">
            {quickLinks.map(link => (
              <a href={link.href} class="quick-pill">{link.label}</a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ── 카테고리 탭 ── -->
    <section class="section">
      <div class="container">
        <CategoryNav />
      </div>
    </section>

    <!-- ── 선물 가이드 그리드 ── -->
    <section class="section">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">
            <i class="ti ti-star" aria-hidden="true"></i>
            인기 선물 가이드
          </h2>
          <a href="/선물/" class="section-more">전체 {guides.length}개 보기 →</a>
        </div>

        <div class="guide-grid">
          {featured.map(guide => (
            <GiftCard guide={guide} />
          ))}
        </div>
      </div>
    </section>

    <!-- ── 나이대 빠른 탐색 ── -->
    <section class="section age-section">
      <div class="container">
        <h2 class="section-title">
          <i class="ti ti-users" aria-hidden="true"></i>
          나이대별로 찾기
        </h2>
        <div class="age-grid">
          {[
            { label: '7세 이하', sub: '유아', href: '/나이/7세/', icon: 'ti-baby-carriage' },
            { label: '초등학생', sub: '8~12세', href: '/나이/초등학생/', icon: 'ti-school' },
            { label: '중학생', sub: '13~15세', href: '/나이/중학생/', icon: 'ti-backpack' },
            { label: '고등학생', sub: '16~18세', href: '/나이/고등학생/', icon: 'ti-book' },
            { label: '20대', sub: '대학생·직장인', href: '/나이/20대/', icon: 'ti-coffee' },
            { label: '30대', sub: '부모·직장인', href: '/나이/30대/', icon: 'ti-briefcase' },
            { label: '40~50대', sub: '중장년', href: '/나이/40대/', icon: 'ti-heart' },
          ].map(item => (
            <a href={item.href} class="age-tile">
              <i class={`ti ${item.icon} age-tile-icon`} aria-hidden="true"></i>
              <strong class="age-tile-label">{item.label}</strong>
              <span class="age-tile-sub">{item.sub}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ── 상황별 ── -->
    <section class="section occasion-section">
      <div class="container">
        <h2 class="section-title">
          <i class="ti ti-calendar-event" aria-hidden="true"></i>
          상황별로 찾기
        </h2>
        <div class="occasion-list">
          {[
            { label: '생일선물', href: '/상황/생일/', emoji: '🎂' },
            { label: '크리스마스', href: '/상황/크리스마스/', emoji: '🎄' },
            { label: '어린이날', href: '/상황/어린이날/', emoji: '🎡' },
            { label: '어버이날', href: '/상황/어버이날/', emoji: '💐' },
            { label: '졸업선물', href: '/상황/졸업/', emoji: '🎓' },
            { label: '입학선물', href: '/상황/입학/', emoji: '🎒' },
            { label: '스승의날', href: '/상황/스승의날/', emoji: '📚' },
            { label: '집들이선물', href: '/상황/집들이/', emoji: '🏠' },
            { label: '취직축하', href: '/선물/취직축하-선물/', emoji: '💼' },
            { label: '승진축하', href: '/선물/승진축하-선물/', emoji: '🏆' },
            { label: '결혼축하', href: '/선물/결혼축하-선물/', emoji: '💍' },
            { label: '출산축하', href: '/선물/출산축하-선물/', emoji: '🍼' },
            { label: '결혼기념일', href: '/선물/결혼기념일-선물/', emoji: '🥂' },
            { label: '환갑선물', href: '/선물/환갑-선물/', emoji: '🎊' },
            { label: '퇴직선물', href: '/선물/퇴직-선물/', emoji: '✈️' },
          ].map(item => (
            <a href={item.href} class="occasion-chip">
              <span aria-hidden="true">{item.emoji}</span>
              {item.label}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ── 아이템별 ── -->
    <section class="section item-section">
      <div class="container">
        <h2 class="section-title">
          <i class="ti ti-shopping-bag" aria-hidden="true"></i>
          아이템별로 찾기
        </h2>
        <p class="section-desc">선물 아이템을 먼저 떠올리셨나요? 누구에게, 어떤 가격대로 사야 할지 정리해드립니다.</p>
        <div class="item-list">
          {[
            { label: '지갑', href: '/선물/지갑-선물-추천/', emoji: '👜' },
            { label: '향수', href: '/선물/향수-선물-추천/', emoji: '🌸' },
            { label: '텀블러', href: '/선물/텀블러-선물-추천/', emoji: '☕' },
            { label: '귀걸이', href: '/선물/귀걸이-선물-추천/', emoji: '💎' },
            { label: '스킨케어', href: '/선물/스킨케어-선물-추천/', emoji: '🧴' },
            { label: '캔들', href: '/선물/캔들-선물-추천/', emoji: '🕯️' },
            { label: '가방', href: '/선물/가방-선물-추천/', emoji: '👝' },
          ].map(item => (
            <a href={item.href} class="occasion-chip">
              <span aria-hidden="true">{item.emoji}</span>
              {item.label}
            </a>
          ))}
        </div>
        <a href="/아이템/" class="item-more-link">아이템별 가이드 전체 보기 →</a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* ── 히어로 ── */
  .hero {
    background: linear-gradient(160deg, #F5F3FF 0%, #FFF7ED 60%, #FFFFFF 100%);
    padding: var(--space-16) 0 var(--space-10);
    border-bottom: 1px solid var(--color-border-subtle);
  }
  .hero-text { margin-bottom: var(--space-8); }
  .hero-title {
    font-size: clamp(var(--text-3xl), 5vw, 3rem);
    font-weight: var(--font-weight-bold);
    line-height: var(--leading-tight);
    color: var(--color-text);
    margin-bottom: var(--space-4);
    letter-spacing: -0.02em;
  }
  .hero-title em {
    font-style: normal;
    color: var(--color-primary);
  }
  .hero-subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    max-width: 560px;
  }

  /* 빠른 링크 */
  .quick-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-6);
  }
  .quick-label {
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-light);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .quick-pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .quick-pill {
    padding: var(--space-2) var(--space-4);
    background: white;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    color: var(--color-text);
    text-decoration: none;
    transition: all var(--transition-fast);
    white-space: nowrap;
  }
  .quick-pill:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    background: var(--color-primary-light);
  }

  /* ── 섹션 공통 ── */
  .section { padding: var(--space-10) 0; }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-6);
  }
  .section-title {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-2xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
  }
  .section-title i { color: var(--color-primary); }
  .section-count {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    background: var(--color-bg-subtle);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border);
  }
  .section-more {
    font-size: var(--text-sm);
    color: var(--color-primary);
    text-decoration: none;
    font-weight: var(--font-weight-medium);
  }
  .section-more:hover { text-decoration: underline; }
  .section-desc {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
    margin-top: var(--space-1);
  }

  /* ── 가이드 그리드 ── */
  .guide-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }
  @media (min-width: 480px) { .guide-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 900px) { .guide-grid { grid-template-columns: repeat(3, 1fr); } }

  /* ── 나이대 ── */
  .age-section { background: var(--color-bg-subtle); }
  .age-section .section-title { margin-bottom: var(--space-6); }
  .age-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }
  @media (min-width: 640px) { .age-grid { grid-template-columns: repeat(4, 1fr); } }
  @media (min-width: 900px) { .age-grid { grid-template-columns: repeat(7, 1fr); } }

  .age-tile {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-3);
    background: white;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-xl);
    text-decoration: none;
    text-align: center;
    transition: all var(--transition-fast);
  }
  .age-tile:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-card);
    transform: translateY(-1px);
  }
  .age-tile-icon { font-size: 1.6rem; color: var(--color-primary); }
  .age-tile-label { font-size: var(--text-sm); font-weight: var(--font-weight-semibold); color: var(--color-text); }
  .age-tile-sub { font-size: var(--text-xs); color: var(--color-text-light); }

  /* ── 아이템별 ── */
  .item-section { background: var(--color-bg-subtle); }
  .item-section .section-title { margin-bottom: 0; }
  .item-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-4);
    margin-bottom: var(--space-4);
  }
  .item-more-link {
    display: inline-block;
    font-size: var(--text-sm);
    color: var(--color-primary);
    text-decoration: none;
    font-weight: var(--font-weight-medium);
    margin-top: var(--space-2);
  }
  .item-more-link:hover { text-decoration: underline; }

  /* ── 상황별 ── */
  .occasion-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-6);
  }
  .occasion-chip {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-5);
    background: white;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-full);
    font-size: var(--text-base);
    font-weight: var(--font-weight-medium);
    color: var(--color-text);
    text-decoration: none;
    transition: all var(--transition-fast);
  }
  .occasion-chip:hover {
    border-color: var(--color-primary);
    background: var(--color-primary-light);
    color: var(--color-primary-dark);
  }
</style>
