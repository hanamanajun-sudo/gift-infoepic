---
import GuideLayout from '../../layouts/GuideLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import GiftCard from '../../components/GiftCard.astro';
import { getGiftGuides, getGiftGuideBySlug, getGuideContent, getProducts } from '../../lib/notion';
import { searchCoupangProducts } from '../../lib/coupang';

export const getStaticPaths = async () => {
  const guides = await getGiftGuides();
  return guides.map(guide => ({
    params: { slug: guide.slug },
    props: { guide, allGuides: guides },
  }));
};

const { guide, allGuides } = Astro.props;

const coupangKeyword = [
  ...guide.relation.slice(0, 1),
  ...guide.occasion.slice(0, 1),
  '선물',
].filter(Boolean).join(' ') || guide.title;

const [{ html: content, headings }, products, coupangProducts] = await Promise.all([
  getGuideContent(guide.id),
  getProducts(guide.id),
  searchCoupangProducts(coupangKeyword),
]);

// ── 연관 가이드 ──
const related = allGuides
  .filter(g => g.slug !== guide.slug)
  .map(g => {
    let score = 0;
    if (g.occasion.some(o => guide.occasion.includes(o))) score += 3;
    if (g.relation.some(r => guide.relation.includes(r))) score += 2;
    if (g.ageGroup.some(a => guide.ageGroup.includes(a))) score += 2;
    if (g.budgetTag.some(b => guide.budgetTag.includes(b))) score += 1;
    return { g, score };
  })
  .filter(({ score }) => score > 0)
  .sort((a, b) => b.score - a.score)
  .slice(0, 3)
  .map(({ g }) => g);

// ── 검증: 상품-H3 개수만 확인 ──
if (products.length > 0 && content) {
  const allH3s = [...content.matchAll(/<h3[^>]*id="[^"]*"[^>]*>.*?<\/h3>/g)] || [];
  if (allH3s.length < products.length) {
    console.warn(`⚠️ [${guide.slug}] H3(${allH3s.length}) < products(${products.length}) — 설명 블록 부족!`);
  }
}

// ── 본문: 통합 상품 카드 위에, 나머지 전체 본문 아래 ──
type ProductSection = { h3: string; paragraph: string };
// products와 blocks(H3+p)가 1:1 매칭되면 각 상품을 카드로 렌더링
// 그 외 블록(가격대별표, 고르는법, 사지마세요, FAQ)은 전체 본문으로 표시
let remainingHtml = content;
const productSections: ProductSection[] = [];

// blocks의 H3+p 쌍을 products와 매칭 (앞부분만 추출)
if (products.length > 0 && content) {
  // 임시 DOM 없이 간단한 문자열 파싱: 각 상품 설명(H3 + 다음 P) 찾기
  const h3Regex = /<h3[^>]*id="[^"]*"[^>]*>.*?<\/h3>/g;
  const matches = [...content.matchAll(h3Regex)];
  
  // 첫 번째 H3의 위치
  const firstH3 = matches[0];
  if (firstH3 && firstH3.index !== undefined) {
    // 첫 H3 앞부분은 remainingHtml로
    const beforeFirst = content.slice(0, firstH3.index);
    
    // 각 상품의 H3+P 추출
    for (let i = 0; i < Math.min(products.length, matches.length); i++) {
      const m = matches[i];
      const h3Text = m[0].replace(/<[^>]+>/g, '').trim();
      
      // H3 뒤의 P 찾기 (바로 다음 P)
      const afterH3 = content.slice(m.index! + m[0].length);
      const pMatch = afterH3.match(/^[\s\n]*<p>.*?<\/p>/);
      const pText = pMatch ? pMatch[0].replace(/<[^>]+>/g, '').trim() : '';
      
      productSections.push({ h3: h3Text, paragraph: pText });
    }
    
    // 마지막 상품 H3+P 이후의 모든 내용을 remainingHtml로
    const lastMatch = matches[Math.min(products.length, matches.length) - 1];
    if (lastMatch && lastMatch.index !== undefined) {
      const afterLast = content.slice(lastMatch.index + lastMatch[0].length);
      const afterLastPMatch = afterLast.match(/^[\s\n]*<p>.*?<\/p>/);
      const afterP = afterLastPMatch
        ? afterLast.slice(afterLastPMatch.index! + afterLastPMatch[0].length)
        : afterLast;
      remainingHtml = beforeFirst + afterP;
    }
  }
}

// 상품-설명 페어링 개수만큼만 상품 표시
const pairedCount = Math.min(products.length, productSections.length);
---

<GuideLayout guide={guide} headings={headings} products={products}>

  <!-- ── 추천 상품 섹션 (통합형) ── -->
  {pairedCount > 0 && (
    <section class="merged-products" aria-labelledby="products-heading">
      <p class="affiliate-notice">이 포스팅은 쿠팡 파트너스 활동의 일환으로, 일정액의 수수료를 제공받을 수 있습니다.</p>
      <h2 id="products-heading" class="products-title">
        <i class="ti ti-star-filled" aria-hidden="true"></i>
        추천 선물 TOP{pairedCount}
      </h2>

      <div class="product-flow">
        {products.slice(0, pairedCount).map((product, i) => {
          const section = productSections[i];
          return (
            <article class="merged-product-card" id={`product-${i + 1}`}>
              <!-- 순위 배지 -->
              <div class="rank-badge" aria-label={`${i + 1}위`}>{i + 1}</div>

              <!-- 상품 이미지 (크게) -->
              {product.imageUrl && (
                <div class="product-hero-img">
                  <img
                    src={product.imageUrl}
                    alt={product.name}
                    loading={i === 0 ? 'eager' : 'lazy'}
                    decoding="async"
                  />
                </div>
              )}

              <!-- 상품 설명 (H3 문구) -->
              {section.h3 && <h3 class="product-desc-heading">{section.h3}</h3>}

              <!-- 상품 설명 (본문) -->
              {section.paragraph && <p class="product-desc-text">{section.paragraph}</p>}

              <!-- 상품 정보 카드 -->
              <div class="product-meta">
                <div class="product-meta-header">
                  <h4 class="product-meta-name">{product.name}</h4>
                  {product.price && (
                    <span class="product-meta-price">
                      {product.price.toLocaleString('ko-KR')}원
                    </span>
                  )}
                </div>

                {product.pros && (
                  <p class="product-meta-pros">{product.pros}</p>
                )}

                <!-- 구매 링크 -->
                {(product.naverUrl || product.coupangUrl) && (
                  <div class="product-meta-links">
                    {product.naverUrl && product.naverUrl !== '#' && (
                      <a
                        href={product.naverUrl}
                        target="_blank"
                        rel="noopener noreferrer nofollow"
                        class="product-link-btn naver"
                        onclick={`gtag('event','product_click',{'guide':'${guide.slug}','product':'${product.name.replace(/'/g,"")}','price':${product.price},'channel':'naver'})`}
                      >
                        <i class="ti ti-external-link" aria-hidden="true"></i>
                        네이버 쇼핑 최저가 확인
                      </a>
                    )}
                    {product.coupangUrl && product.coupangUrl !== '#' && (
                      <a
                        href={product.coupangUrl}
                        target="_blank"
                        rel="noopener noreferrer sponsored"
                        class="product-link-btn coupang"
                        onclick={`gtag('event','product_click',{'guide':'${guide.slug}','product':'${product.name.replace(/'/g,"")}','price':${product.price},'channel':'coupang'})`}
                      >
                        <i class="ti ti-shopping-cart" aria-hidden="true"></i>
                        쿠팡 최저가 확인
                      </a>
                    )}
                  </div>
                )}
              </div>
            </article>
          );
        })}
      </div>
    </section>
  )}

  <!-- ── 나머지 본문 (가격대별표, 선택법, 사지마세요, FAQ 등) ── -->
  {remainingHtml && remainingHtml.trim() && (
    <article class="guide-content" data-pagefind-body>
      <div set:html={remainingHtml} />
    </article>
  )}

  <!-- ── 관심사 태그 ── -->
  {guide.interests.length > 0 && (
    <div class="interests-tags">
      <span class="interests-label">관련 키워드</span>
      {guide.interests.map(interest => (
        <span class="badge badge-neutral">{interest}</span>
      ))}
      {guide.relation.map(rel => (
        <span class="badge badge-neutral">{rel}</span>
      ))}
    </div>
  )}

  <!-- ── 쿠팡 실시간 추천 ── -->
  {coupangProducts.length > 0 && (
    <section class="coupang-section" aria-labelledby="coupang-heading">
      <h2 id="coupang-heading" class="coupang-title">
        <i class="ti ti-shopping-cart" aria-hidden="true"></i>
        쿠팡 실시간 추천 상품
      </h2>
      <p class="coupang-sub">이 가이드와 관련된 쿠팡 상품이에요.</p>
      <div class="coupang-grid">
        {coupangProducts.map(p => (
          <a
            href={p.productUrl}
            target="_blank"
            rel="noopener noreferrer nofollow"
            class="coupang-card"
          >
            <div class="coupang-img-wrap">
              <img src={p.productImage} alt={p.productName} loading="lazy" decoding="async" width="200" height="200" />
            </div>
            <div class="coupang-info">
              <p class="coupang-name">{p.productName}</p>
              <p class="coupang-price">{p.productPrice.toLocaleString('ko-KR')}원</p>
              {p.isRocket && <span class="rocket-badge">로켓배송</span>}
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- ── 연관 가이드 ── -->
  {related.length > 0 && (
    <section class="related-section" aria-labelledby="related-heading">
      <h2 id="related-heading" class="related-title">
        <i class="ti ti-arrow-right" aria-hidden="true"></i>
        이런 선물 가이드도 있어요
      </h2>
      <div class="related-grid">
        {related.map(g => <GiftCard guide={g} />)}
      </div>
    </section>
  )}
</GuideLayout>

<style>
  /* ── 통합 상품 카드 ── */
  .merged-products { margin-bottom: var(--space-10); }
  .affiliate-notice {
    font-size: var(--text-xs);
    color: var(--color-text-light);
    text-align: center;
    margin-bottom: var(--space-4);
    padding: var(--space-2);
    background: var(--color-bg-subtle);
    border-radius: var(--radius-md);
  }
  .products-title {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-2xl);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--space-6);
    color: var(--color-text);
  }
  .products-title i { color: var(--color-accent); }

  .product-flow {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .merged-product-card {
    position: relative;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: var(--color-bg);
  }

  .rank-badge {
    position: absolute;
    top: var(--space-3);
    left: var(--space-3);
    width: 32px;
    height: 32px;
    border-radius: var(--radius-full);
    background: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-base);
    font-weight: var(--font-weight-bold);
    color: white;
    z-index: 2;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
  }
  .rank-badge[aria-label="1위"] { background: #F59E0B; }
  .rank-badge[aria-label="2위"] { background: #9CA3AF; }
  .rank-badge[aria-label="3위"] { background: #CD7C2F; }

  /* 이미지 (전체 20% 축소, 비율 유지) */
  .product-hero-img {
    width: 80%;
    margin: var(--space-4) auto 0;
    aspect-ratio: 16/9;
    overflow: hidden;
    background: var(--color-bg-subtle);
    border-radius: var(--radius-lg);
  }
  .product-hero-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* 설명 H3 */
  .product-desc-heading {
    font-size: var(--text-xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    padding: var(--space-5) var(--space-5) 0;
    margin: 0;
  }

  .product-desc-text {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    padding: var(--space-3) var(--space-5) 0;
    margin: 0;
  }

  /* 상품 정보 카드 (하단) */
  .product-meta {
    padding: var(--space-5);
    margin: var(--space-4);
    border-radius: var(--radius-lg);
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
  }

  .product-meta-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .product-meta-name {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
    flex: 1;
    line-height: var(--leading-snug);
    margin: 0;
  }
  .product-meta-price {
    font-size: var(--text-lg);
    font-weight: var(--font-weight-bold);
    color: var(--color-primary-dark);
    white-space: nowrap;
  }

  .product-meta-pros {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    margin: var(--space-2) 0 0;
  }

  .product-meta-links {
    display: flex;
    gap: var(--space-2);
    margin-top: var(--space-3);
    flex-wrap: wrap;
  }

  .product-link-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    text-decoration: none;
    transition: all var(--transition-fast);
  }
  .product-link-btn.coupang {
    background: #FEF3C7;
    color: #92400E;
  }
  .product-link-btn.coupang:hover { background: #F59E0B; color: white; }
  .product-link-btn.naver {
    background: #DCFCE7;
    color: #14532D;
  }
  .product-link-btn.naver:hover { background: #16A34A; color: white; }

  /* ── (기존 스타일 유지) ── */
  .interests-tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    margin: var(--space-8) 0;
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
  }
  .interests-label {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-muted);
    margin-right: var(--space-2);
  }
  .coupang-section {
    margin: var(--space-12) 0;
    padding-top: var(--space-8);
    border-top: 2px solid var(--color-border-subtle);
  }
  .coupang-title {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xl);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--space-2);
    color: var(--color-text);
  }
  .coupang-title i { color: #E4393C; }
  .coupang-sub {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-5);
  }
  .coupang-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }
  @media (min-width: 640px) { .coupang-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 900px) { .coupang-grid { grid-template-columns: repeat(4, 1fr); } }
  .coupang-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: box-shadow var(--transition-fast), transform var(--transition-fast);
  }
  .coupang-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
  .coupang-img-wrap { width: 100%; aspect-ratio: 1; overflow: hidden; background: var(--color-bg-subtle); }
  .coupang-img-wrap img { width: 100%; height: 100%; object-fit: cover; }
  .coupang-info { padding: var(--space-3); display: flex; flex-direction: column; gap: var(--space-1); }
  .coupang-name { font-size: var(--text-xs); color: var(--color-text); line-height: var(--leading-snug); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .coupang-price { font-size: var(--text-sm); font-weight: var(--font-weight-bold); color: var(--color-primary-dark); }
  .rocket-badge { display: inline-block; font-size: 10px; padding: 2px 6px; border-radius: var(--radius-full); background: #E4393C; color: white; font-weight: var(--font-weight-semibold); width: fit-content; }
  .related-section { margin-top: var(--space-12); padding-top: var(--space-8); border-top: 2px solid var(--color-border-subtle); }
  .related-title { display: flex; align-items: center; gap: var(--space-2); font-size: var(--text-xl); font-weight: var(--font-weight-bold); margin-bottom: var(--space-5); color: var(--color-text); }
  .related-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-4); }
  @media (min-width: 640px) { .related-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 900px) { .related-grid { grid-template-columns: repeat(3, 1fr); } }
</style>
