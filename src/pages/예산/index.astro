---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CategoryNav from '../../components/CategoryNav.astro';
import { getGiftGuides } from '../../lib/notion';

const guides = await getGiftGuides();
const budgetMap = new Map<string, number>();
guides.forEach(g => g.budgetTag.forEach(b => {
  budgetMap.set(b, (budgetMap.get(b) ?? 0) + 1);
}));

const ORDER = ['1만원이하', '2만원이하', '3만원이하', '5만원이하', '10만원이하', '20만원이하', '20만원이상'];
const budgets = [...budgetMap.entries()]
  .map(([tag, count]) => ({ tag, count }))
  .sort((a, b) => {
    const ia = ORDER.indexOf(a.tag);
    const ib = ORDER.indexOf(b.tag);
    if (ia >= 0 && ib >= 0) return ia - ib;
    if (ia >= 0) return -1;
    return 1;
  });
---

<BaseLayout
  title="예산별 선물 추천 — 3만원 이하, 5만원 이하 선물 가이드"
  description="예산에 맞는 선물을 빠르게 찾아보세요. 1만원부터 20만원 이상까지, 예산별 선물 추천 가이드."
>
  <Header />

  <main class="container" style="padding-top:var(--space-10);padding-bottom:var(--space-16)">
    <CategoryNav activeHref="/예산/" />

    <header class="page-header">
      <h1 class="page-title">
        <i class="ti ti-wallet" aria-hidden="true"></i>
        예산별 선물 가이드
      </h1>
      <p class="page-desc">선물 예산을 선택하면 딱 맞는 가이드를 볼 수 있어요.</p>
    </header>

    <div class="filter-grid">
      {budgets.map(({ tag, count }) => (
        <a href={`/예산/${tag}/`} class="budget-tile">
          <i class="ti ti-cash-banknote budget-icon" aria-hidden="true"></i>
          <span class="budget-name">{tag}</span>
          <span class="budget-count">가이드 {count}개</span>
        </a>
      ))}
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .page-header { margin-bottom: var(--space-8); }
  .page-title {
    display: flex; align-items: center; gap: var(--space-3);
    font-size: var(--text-3xl); font-weight: var(--font-weight-bold); margin-bottom: var(--space-3);
  }
  .page-title i { color: var(--color-primary); }
  .page-desc { font-size: var(--text-lg); color: var(--color-text-muted); }

  .filter-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-3);
  }
  @media (min-width: 480px) { .filter-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 768px) { .filter-grid { grid-template-columns: repeat(4, 1fr); } }

  .budget-tile {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: var(--space-2); padding: var(--space-5);
    background: var(--color-bg); border: 1.5px solid var(--color-border);
    border-radius: var(--radius-xl); text-decoration: none; text-align: center;
    transition: all var(--transition-fast);
  }
  .budget-tile:hover {
    border-color: var(--color-accent); background: var(--color-accent-light);
    transform: translateY(-2px); box-shadow: var(--shadow-card);
  }
  .budget-icon { font-size: 1.8rem; color: var(--color-accent-dark); }
  .budget-name { font-size: var(--text-xl); font-weight: var(--font-weight-bold); color: var(--color-text); }
  .budget-count { font-size: var(--text-sm); color: var(--color-text-muted); }
  .budget-tile:hover .budget-name { color: var(--color-accent-dark); }
</style>
