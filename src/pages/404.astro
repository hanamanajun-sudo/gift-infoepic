---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="페이지를 찾을 수 없습니다 — 선물추천 가이드"
  description="요청하신 페이지를 찾을 수 없습니다."
  noindex={true}
>
  <Header />

  <main class="container" style="padding-top:var(--space-20);padding-bottom:var(--space-20);text-align:center">
    <div class="not-found">
      <div class="nf-icon" aria-hidden="true">
        <i class="ti ti-gift-off"></i>
      </div>
      <h1 class="nf-title">페이지를 찾을 수 없어요</h1>
      <p class="nf-desc">
        찾으시는 선물 가이드가 이동되었거나 삭제되었을 수 있습니다.
      </p>
      <div class="nf-actions">
        <a href="/" class="btn btn-primary">홈으로 돌아가기</a>
        <a href="/나이/" class="btn btn-outline">나이별 선물 보기</a>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .not-found {
    display: flex; flex-direction: column; align-items: center; gap: var(--space-5);
    max-width: 480px; margin: 0 auto;
  }
  .nf-icon {
    font-size: 5rem; color: var(--color-primary-light);
    line-height: 1;
  }
  .nf-title {
    font-size: var(--text-3xl); font-weight: var(--font-weight-bold); color: var(--color-text);
  }
  .nf-desc { font-size: var(--text-lg); color: var(--color-text-muted); }
  .nf-actions { display: flex; gap: var(--space-3); flex-wrap: wrap; justify-content: center; margin-top: var(--space-3); }
</style>
